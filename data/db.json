    "ideas": [
      {
        "title": "The Buddy Card",
        "note": "One little tango identity that travels with you — from your first lesson to your hundredth milonga, carried in one place."
      },
      {
        "title": "Community network",
        "note": "Weave newcomers, buddies and organizers into one warm, connected Boston tango community."
      },
      {
        "title": "Rolling participation lifecycle",
        "note": "Follow the whole journey — curious newcomer → dancing regular → buddy for the next newcomer — and keep it rolling."
      },
      {
        "title": "Organizer ↔ community chat",
        "note": "A friendly room where hosts and dancers talk directly — ask the locals anything before you even arrive."
      },
      {
        "title": "Multi-city",
        "note": "The same warm on-ramp beyond Boston — a buddy waiting wherever tango is danced."
      },
      {
        "title": "Deeper TangoTiempo connection",
        "note": "Link the community layer to the wider TangoTiempo world so events and people flow together."
      }
    ],
    "todos": [
      {
        "title": "Token device-landing",
        "note": "A returning visitor's device remembers them and lands on their events / check-in home instead of the sign-up."
      },
      {
        "title": "Real organizers",
        "note": "Swap the demo placeholders for real Boston teachers and organizers — details coming from Toby."
      },
      {
        "title": "Rolling lifecycle demo",
        "note": "A worked demo of the rolling participation lifecycle end to end."
      }
    ]
  },
